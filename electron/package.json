{
  "name": "dutyslip",
  "version": "1.0.0",
  "description": "DutySlip Desktop Control Panel",
  "main": "main.js",
  "author": "Huzefa Saleem",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win",
    "lint": "eslint ."
  },
  "build": {
    "appId": "com.dutyslip.app",
    "productName": "DutySlip",
    "publish": {
      "provider": "github",
      "owner": "huzefa897",
      "repo": "DutySlip"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "../docker-compose.prod.yml",
        "to": "docker-compose.yml"
      },
      {
        "from": "../.env.example",
        "to": ".env"
      }
    ],
    "mac": {
      "icon": "assets/icon.png",
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^9.39.4",
    "globals": "^17.6.0"
  },
  "dependencies": {
    "lint": "^1.2.2"
  }
}
